# ESPHome secrets for TruLight BLE Proxy
#
# Copy this file to your ESPHome secrets.yaml:
#   - If using the ESPHome HA addon: /config/esphome/secrets.yaml
#   - If using ESPHome CLI: ~/.esphome/secrets.yaml (or same dir as your config)
#
# Generate values with:
#   API key:      openssl rand -base64 32
#   OTA password: openssl rand -hex 16

api_key: "REPLACE_WITH_BASE64_KEY"
ota_password: "REPLACE_WITH_HEX_PASSWORD"
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"
